{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for travelers.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "twitter": { "type": "string" },
            "website": { "type": "string" }
          }
        },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Post": {
      "title": "Travel Story",
      "description": "A travel story shared by a user.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "location": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "reactions": {
          "type": "object",
          "properties": {
            "count": { "type": "integer" },
            "userIds": { "type": "array", "items": { "type": "string" } }
          }
        },
        "commentsCount": { "type": "integer" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "twitter": { "type": "string" }
          }
        }
      },
      "required": ["authorId", "title", "content", "timestamp", "status"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a travel story.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/posts/{postId}": { "schema": "Post", "description": "Travel stories" },
    "/posts/{postId}/comments/{commentId}": { "schema": "Comment", "description": "Comments on posts" }
  }
}
